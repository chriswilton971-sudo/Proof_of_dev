# Deployer wallet private key (NEVER commit .env, only .env.example)
DEPLOYER_PRIVATE_KEY=

# RPC endpoints
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
LOCALHOST_RPC_URL=http://127.0.0.1:8545

# Trusted signer address for EIP-712 attestations
SIGNER_ADDRESS=

# NFT metadata base URI
NFT_METADATA_BASE_URI=http://localhost:3000/api/token

# Frontend app URL (used if NFT_METADATA_BASE_URI not set)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Contract address (set after deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Alchemy API key for RPC
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Enable gas reporting
REPORT_GAS=false
