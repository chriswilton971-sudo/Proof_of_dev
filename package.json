{
  "name": "proof-of-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0 <23.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "node infra/scripts/dev.js",
    "start": "node infra/scripts/dev.js",
    "build": "node packages/scoring-spec/generate.js && npm run build --workspace=@proof-of-dev/web",
    "lint": "npm run lint --workspace=@proof-of-dev/web",
    "check:env": "node scripts/check-env.js",
    "generate:scoring": "node packages/scoring-spec/generate.js",
    "onchain:compile": "node scripts/compile-contract.js",
    "onchain:deploy": "tsx scripts/deploy.ts",
    "onchain:register-schema": "tsx scripts/registerSchema.ts",
    "seed:wallet": "node scripts/seed-indexed-wallet.js",
    "test:scoring": "node --test tests/scoring-parity.test.js",
    "test": "npm run test:scoring"
  },
  "devDependencies": {
    "@ethereum-attestation-service/eas-sdk": "2.9.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "tsx": "^4.22.4"
  }
}
